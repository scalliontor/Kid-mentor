<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ELDER_CARE: quét thuốc bằng camera -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:name=".PtalkApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Ptalk_child">

        <!-- SplashActivity là màn hình khởi động -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.Ptalk_child">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ModeSelectActivity — chọn Kid Mentor / Elder Care -->
        <!-- noHistory bỏ đi để có thể mở Settings rồi back lại; vào Main luôn CLEAR_TASK. -->
        <activity
            android:name=".ModeSelectActivity"
            android:exported="false"
            android:theme="@style/Theme.Ptalk_child" />

        <!-- LoginActivity — màn hình đăng nhập giả -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- MainActivity là màn hình chính -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- MedicineScannerActivity — quét thuốc (ELDER_CARE) -->
        <activity
            android:name=".MedicineScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- SubscriptionActivity — màn Gói Đăng Ký -->
        <activity
            android:name=".SubscriptionActivity"
            android:exported="false" />

        <!-- SettingsActivity — cài đặt dùng chung cho cả hai chế độ -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ParentChildInfoActivity — thông tin phụ huynh + con (chỉ KID_MENTOR, đọc) -->
        <activity
            android:name=".ParentChildInfoActivity"
            android:exported="false" />

        <!-- Per-app language (vi/en/system): AppCompat auto-stores & re-applies the
             chosen locale before any Activity is created. See LocalePrefs. -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>

</manifest>