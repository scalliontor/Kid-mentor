<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FDEBD0" />
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#F5A623"
                android:endColor="#E8871E" />
            <stroke
                android:width="2dp"
                android:color="#FFF5E6" />
        </shape>
    </item>
</layer-list>
