<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted glass card holding the greeting (ready to host live text later). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="24dp" />
    <gradient android:angle="135" android:type="linear"
        android:startColor="@color/greeting_card_top"
        android:endColor="@color/greeting_card_bottom" />
    <stroke android:width="1dp" android:color="@color/greeting_card_stroke" />
</shape>
