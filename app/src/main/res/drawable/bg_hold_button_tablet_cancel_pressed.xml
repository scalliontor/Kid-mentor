<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FAD7A0" />
        </shape>
    </item>
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#E8871E"
                android:endColor="#D4751A" />
            <stroke
                android:width="2dp"
                android:color="#FDEBD0" />
        </shape>
    </item>
</layer-list>
