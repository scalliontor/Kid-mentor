<?xml version="1.0" encoding="utf-8"?>
<!-- Assistant (mascot) speech bubble — left aligned, white, with a small tail
     on the bottom-left corner. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/km_bubble_assistant" />
    <corners
        android:topLeftRadius="@dimen/km_radius_lg"
        android:topRightRadius="@dimen/km_radius_lg"
        android:bottomRightRadius="@dimen/km_radius_lg"
        android:bottomLeftRadius="@dimen/km_radius_bubble_tail" />
    <stroke
        android:width="1dp"
        android:color="@color/km_bubble_assistant_border" />
</shape>
