<?xml version="1.0" encoding="utf-8"?>
<!-- Soft circular chip behind the call / settings icons so they read as buttons
     on a bright background. Colours flip in values-night. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/icon_btn_soft_press" />
            <stroke android:width="1dp" android:color="@color/icon_btn_soft_stroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/icon_btn_soft_bg" />
            <stroke android:width="1dp" android:color="@color/icon_btn_soft_stroke" />
        </shape>
    </item>
</selector>
