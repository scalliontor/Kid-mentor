<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Bo góc (Rounded corners) -->
    <corners android:radius="24dp" />
    
    <!-- Light mode: Kính mờ trắng đục hơn, dễ nhìn trên nền pastel sáng -->
    <gradient
        android:angle="135"
        android:startColor="#FFFFFFFF"
        android:centerColor="#F2FFFFFF"
        android:endColor="#E6FFFFFF"
        android:type="linear" />
        
    <!-- Viền sáng mỏng tạo cảm giác khối nổi (Glass edge) -->
    <stroke
        android:width="1dp"
        android:color="#80FFFFFF" />
</shape>
