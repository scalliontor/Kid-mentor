<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- ══ BACKGROUND EFFECTS ═══════════════════════════════════════════ -->
    <com.buivan.ptalk_child.StarFieldView
        android:id="@+id/bgStarField"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.buivan.ptalk_child.WaveView
        android:id="@+id/bgWaveEffect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Removed brandAccentLine to use glassy header with margins -->
    <View
        android:id="@+id/brandBarBg"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:layout_marginStart="@dimen/space_xl"
        android:layout_marginEnd="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Back button - below brand bar -->
    <ImageView
        android:id="@+id/btnBackMode"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_revert"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:tint="#222222"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivBrandPtitLeft"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="16dp"
        android:contentDescription="PTIT"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_ptit"
        android:elevation="7dp"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg"
        app:layout_constraintTop_toTopOf="@id/brandBarBg" />

    <LinearLayout
        android:id="@+id/brandTextBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="7dp"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/brandBarBg">

        <TextView
            android:id="@+id/tvBrandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:text="PTALK"
            android:textColor="#111111"
            android:textSize="@dimen/text_brand_title" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivBrandCtsRight"
        android:layout_width="@dimen/brand_cts_width"
        android:layout_height="@dimen/brand_cts_height"
        android:layout_marginEnd="@dimen/brand_side_margin"
        android:contentDescription="CTS"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_cts_main"
        android:elevation="7dp"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg"
        app:layout_constraintTop_toTopOf="@id/brandBarBg" />

    <!-- Removed brandBarBottomLine for cleaner glassy look -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Xin chào!"
        android:textColor="#6BAF8A"
        android:textSize="@dimen/text_greeting"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBackMode" />

    <TextView
        android:id="@+id/tvSubGreeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/tablet_main_sub_greeting_top_margin"
        android:layout_marginStart="@dimen/tablet_main_sub_greeting_side_margin"
        android:layout_marginEnd="@dimen/tablet_main_sub_greeting_side_margin"
        android:gravity="center"
        android:text="Hôm nay, tớ có thể giúp gì cho cậu?"
        android:textColor="#2E7D52"
        android:textSize="@dimen/text_sub_greeting"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

    <TextView
        android:id="@+id/tvSTT"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="24dp"
        android:text="STT, công thức"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.buivan.ptalk_child.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:enabled="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        android:layout_marginStart="@dimen/tablet_main_center_side_margin"
        android:layout_marginEnd="@dimen/tablet_main_center_side_margin"
        android:layout_marginTop="@dimen/tablet_main_center_top_margin"
        android:layout_marginBottom="@dimen/tablet_main_center_bottom_margin"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSTT" />

    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:clickable="false"
        android:contentDescription="AI character"
        android:enabled="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        android:scaleType="fitCenter"
        android:src="@drawable/char_idle1"
        app:layout_constraintBottom_toBottomOf="@id/waveformView"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@id/waveformView"
        app:layout_constraintHeight_max="@dimen/tablet_character_max_size"
        app:layout_constraintStart_toStartOf="@id/waveformView"
        app:layout_constraintTop_toTopOf="@id/waveformView"
        app:layout_constraintVertical_bias="0.50"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_max="@dimen/tablet_character_max_size"
        app:layout_constraintWidth_percent="0.90" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_s"
        android:text="Giữ nút để nói chuyện"
        android:textColor="#8BAF9A"
        android:textSize="@dimen/text_status"
        app:layout_constraintBottom_toTopOf="@id/btnCancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierBottomControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="micTouchContainer, containerElderButtons" />

    <!-- Nút cancel (chỉ hiện khi PLAYING) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCancel"
        android:layout_width="160dp"
        android:layout_height="60dp"
        android:text="⏹  DỪNG LẠI"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_cancel_button"
        android:visibility="gone"
        android:elevation="8dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/barrierBottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Bar Container for the curved look -->
    <View
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_bottom_bar"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Left Button: Camera -->
    <LinearLayout
        android:id="@+id/btnCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/micTouchContainer"
        android:layout_marginBottom="16dp">
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#333333" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Right Button: Setting (or Record) -->
    <LinearLayout
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/micTouchContainer"
        android:layout_marginBottom="16dp">
        <ImageView
            android:id="@+id/ivSettingIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#333333" />
        <TextView
            android:id="@+id/tvSettingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setting"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Cancel Zone Shadow (Visible when recording in Kid Mentor) -->
    <View
        android:id="@+id/cancelZoneShadow"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_cancel_zone_ring"
        android:visibility="invisible"
        android:elevation="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/micTouchContainer"
        android:layout_width="@dimen/tablet_main_mic_hit_size"
        android:layout_height="@dimen/tablet_main_mic_hit_size"
        android:layout_marginBottom="@dimen/tablet_main_mic_bottom_margin"
        android:elevation="@dimen/tablet_main_mic_elevation"
        android:padding="@dimen/tablet_main_mic_hit_padding"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnHoldToTalk"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@drawable/bg_hold_button_tablet"
            android:clickable="true"
            android:contentDescription="Ghi âm"
            android:focusable="true"
            android:hapticFeedbackEnabled="true"
            android:importantForAccessibility="yes"
            android:minWidth="@dimen/touch_target_min_size"
            android:minHeight="@dimen/touch_target_min_size"
            android:padding="@dimen/btn_mic_padding"
            android:scaleType="centerInside"
            android:src="@drawable/ic_mic_custom"
            android:tint="#F7FFFB" />

    </FrameLayout>
    
    <!-- ELDER CARE BUTTONS (Symmetric Camera and Mic) -->
    <LinearLayout
        android:id="@+id/containerElderButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <!-- Camera Button (Pastel Orange) -->
        <ImageButton
            android:id="@+id/btnCameraElder"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/bg_circle_orange_pastel"
            android:scaleType="centerInside"
            android:padding="24dp"
            android:elevation="12dp" />

        <!-- Swipe Path Indicator -->
        <LinearLayout
            android:id="@+id/swipePathElder"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="invisible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;&lt;&lt; Vuốt để huỷ"
                android:textColor="#FF5252"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Mic Button (Pastel Green) -->
        <ImageButton
            android:id="@+id/btnHoldToTalkElder"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_mic_custom"
            android:background="@drawable/bg_circle_green_pastel"
            android:scaleType="centerInside"
            android:padding="24dp"
            android:elevation="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
