<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        android:minHeight="@dimen/login_min_height">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/contentStartGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.10" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/contentEndGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.90" />

        <ImageView
            android:id="@+id/ivLoginHero"
            android:layout_width="@dimen/login_hero_size"
            android:layout_height="@dimen/login_hero_size"
            android:layout_marginTop="@dimen/tablet_login_hero_top"
            android:contentDescription="PTIT logo"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_ptit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ══ LANGUAGE SELECTOR TOGGLE ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/btnLanguageToggle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_lang_toggle"
            android:padding="2dp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="@id/ivLoginHero"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvLangVIE"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:text="VIE"
                android:textSize="@dimen/text_login_label"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_lang_selected"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvLangENG"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:text="ENG"
                android:textSize="@dimen/text_login_label"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:textColor="#707072" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLoginHeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:lineSpacingMultiplier="1.05"
            android:text="@string/login_headline"
            android:textColor="#111111"
            android:textSize="@dimen/text_login_headline"
            app:layout_constraintEnd_toStartOf="@id/contentEndGuide"
            app:layout_constraintStart_toStartOf="@id/contentStartGuide"
            app:layout_constraintTop_toBottomOf="@id/ivLoginHero" />

        <TextView
            android:id="@+id/tvLoginSubheadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_s"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:paddingStart="@dimen/tablet_login_subheadline_side_padding"
            android:paddingEnd="@dimen/tablet_login_subheadline_side_padding"
            android:text="@string/login_subheadline"
            android:textColor="#707072"
            android:textSize="@dimen/text_login_subheadline"
            app:layout_constraintEnd_toStartOf="@id/contentEndGuide"
            app:layout_constraintStart_toStartOf="@id/contentStartGuide"
            app:layout_constraintTop_toBottomOf="@id/tvLoginHeadline" />

        <LinearLayout
            android:id="@+id/loginFormCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tablet_login_form_top_margin"
            android:layout_marginStart="@dimen/tablet_login_form_side_margin"
            android:layout_marginEnd="@dimen/tablet_login_form_side_margin"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/contentEndGuide"
            app:layout_constraintStart_toStartOf="@id/contentStartGuide"
            app:layout_constraintTop_toBottomOf="@id/tvLoginSubheadline">

            <TextView
                android:id="@+id/tvLoginError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:fontFamily="sans-serif-medium"
                android:text=""
                android:textColor="#D30005"
                android:textSize="@dimen/text_login_error"
                android:visibility="gone" />

            <!-- Privacy & Terms consent (tablet) — synced with phone layout -->
            <CheckBox
                android:id="@+id/cbAgreeTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/consent_prefix"
                android:textSize="@dimen/text_login_label"
                android:textColor="@color/color_login_subheadline" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:layout_marginStart="32dp">

                <TextView
                    android:id="@+id/tvPrivacyLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_privacy"
                    android:textColor="@color/color_link_blue"
                    android:textSize="@dimen/text_login_label"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_and"
                    android:textSize="@dimen/text_login_label"
                    android:textColor="@color/color_login_subheadline" />

                <TextView
                    android:id="@+id/tvTermsLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_terms"
                    android:textColor="@color/color_link_blue"
                    android:textSize="@dimen/text_login_label"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTermsError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_error"
                android:textSize="@dimen/text_login_error"
                android:textColor="@color/color_login_error"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_xs"
                android:visibility="gone" />

            <!-- SSO Button (Authentik) - Primary login -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSSO"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/space_xl"
                android:background="@drawable/bg_login_button"
                android:text="Đăng nhập với SSO"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_login_button"
                android:drawableStart="@drawable/ic_key"
                android:drawablePadding="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E5E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_or"
                    android:textColor="#9E9EA0"
                    android:textSize="@dimen/text_login_footer" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E5E5" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuest"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/space_m"
                android:background="@drawable/bg_guest_button"
                android:text="@string/login_guest_btn_text"
                android:textColor="#111111"
                android:textSize="@dimen/text_guest_button" />

            <!-- Hidden fields for compatibility -->
            <EditText android:id="@+id/etUsername" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />
            <EditText android:id="@+id/etPassword" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnLogin" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />

            <!-- Register link -->
            <TextView
                android:id="@+id/tvRegisterLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login_register_link"
                android:textSize="@dimen/text_login_label"
                android:textColor="#2563EB"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLoginFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_footer_top"
            android:layout_marginBottom="@dimen/space_footer_bottom"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="@dimen/tablet_login_footer_side_padding"
            android:paddingEnd="@dimen/tablet_login_footer_side_padding"
            android:text="@string/login_footer"
            android:textColor="#9E9EA0"
            android:textSize="@dimen/text_login_footer"
            app:layout_constraintEnd_toStartOf="@id/contentEndGuide"
            app:layout_constraintStart_toStartOf="@id/contentStartGuide"
            app:layout_constraintTop_toBottomOf="@id/loginFormCard"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
