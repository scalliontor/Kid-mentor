<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        android:minHeight="@dimen/login_min_height">

        <!-- ══ HERO SECTION ════════════════════════════════════════════════ -->
        <!-- PTIT Logo big - editorial hero -->
        <ImageView
            android:id="@+id/ivLoginHero"
            android:layout_width="@dimen/login_hero_size"
            android:layout_height="@dimen/login_hero_size"
            android:src="@drawable/logo_ptit"
            android:scaleType="fitCenter"
            android:layout_marginTop="@dimen/space_hero_top"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ LANGUAGE SELECTOR TOGGLE ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/btnLanguageToggle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_lang_toggle"
            android:padding="2dp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="@id/ivLoginHero"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvLangVIE"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:text="VIE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_lang_selected"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvLangENG"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:text="ENG"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:textColor="#707072" />
        </LinearLayout>

        <!-- Display headline (Nike Futura style) -->
        <TextView
            android:id="@+id/tvLoginHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_headline"
            android:textSize="@dimen/text_login_headline"
            android:textColor="#111111"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingMultiplier="0.95"
            android:letterSpacing="0.02"
            android:layout_marginTop="@dimen/space_l"
            app:layout_constraintTop_toBottomOf="@id/ivLoginHero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvLoginSubheadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subheadline"
            android:textSize="@dimen/text_login_subheadline"
            android:textColor="#707072"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_s"
            android:paddingStart="@dimen/subheadline_padding_h"
            android:paddingEnd="@dimen/subheadline_padding_h"
            app:layout_constraintTop_toBottomOf="@id/tvLoginHeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ FORM CARD ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/loginFormCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/space_xxl"
            android:layout_marginStart="@dimen/form_margin_h"
            android:layout_marginEnd="@dimen/form_margin_h"
            app:layout_constraintTop_toBottomOf="@id/tvLoginSubheadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Username label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_username_label"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginBottom="@dimen/space_xs" />

            <!-- Username input -->
            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/login_username_hint"
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="text"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_password_label"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_xs" />

            <!-- Password input -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/login_password_hint"
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="textPassword"
                android:importantForAutofill="no"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <!-- Error text (hidden by default) -->
            <TextView
                android:id="@+id/tvLoginError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_login_error"
                android:textColor="#D30005"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_s"
                android:visibility="gone" />

            <!-- Login button (Nike Black pill) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="@string/login_btn_text"
                android:textSize="@dimen/text_login_button"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_login_button"
                android:layout_marginTop="@dimen/space_xl"
                android:elevation="2dp" />

            <!-- Divider with text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_xl">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E5E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_or"
                    android:textSize="@dimen/text_login_footer"
                    android:textColor="#9E9EA0"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E5E5" />
            </LinearLayout>

            <!-- Guest button (outlined pill) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuest"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="@string/login_guest_btn_text"
                android:textSize="@dimen/text_guest_button"
                android:textColor="#111111"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:background="@drawable/bg_guest_button"
                android:layout_marginTop="@dimen/space_m" />

            <!-- SSO Button (Authentik) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSSO"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="Đăng nhập với SSO"
                android:textSize="@dimen/text_guest_button"
                android:textColor="#2563EB"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:background="@drawable/bg_sso_button"
                android:layout_marginTop="@dimen/space_s"
                android:drawableStart="@drawable/ic_key"
                android:drawablePadding="8dp" />

            <!-- Register link -->
            <TextView
                android:id="@+id/tvRegisterLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login_register_link"
                android:textSize="@dimen/text_login_label"
                android:textColor="#2563EB"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ══ BOTTOM FOOTER ════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvLoginFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/login_footer"
            android:textSize="@dimen/text_login_footer"
            android:textColor="#9E9EA0"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="@dimen/space_footer_top"
            android:layout_marginBottom="@dimen/space_footer_bottom"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h"
            app:layout_constraintTop_toBottomOf="@id/loginFormCard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
