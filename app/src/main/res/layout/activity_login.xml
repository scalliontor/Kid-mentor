<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/login_min_height">

        <!-- ══ TOP RED ACCENT LINE ═════════════════════════════════════════ -->
        <!-- Removed loginAccentLine for cleaner glassy look -->

        <!-- ══ BRAND HEADER ════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/loginBrandHeader"
            android:layout_width="0dp"
            android:layout_height="@dimen/login_header_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h"
            android:layout_marginStart="@dimen/space_l"
            android:layout_marginEnd="@dimen/space_l"
            android:layout_marginTop="@dimen/space_l"
            android:background="@drawable/bg_glass_header"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- PTIT Logo left -->
            <ImageView
                android:layout_width="@dimen/login_ptit_logo_size"
                android:layout_height="@dimen/login_cts_logo_height"
                android:src="@drawable/logo_ptit"
                android:scaleType="fitCenter"
                android:contentDescription="PTIT" />

            <!-- Separator -->
            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/login_header_separator_height"
                android:background="#CACACB"
                android:layout_marginStart="@dimen/login_header_separator_margin"
                android:layout_marginEnd="@dimen/login_header_separator_margin" />

            <!-- App name block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PTALK"
                    android:textSize="@dimen/text_login_header_title"
                    android:textColor="#111111"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06" />
            </LinearLayout>

            <!-- CTS Logo right -->
            <ImageView
                android:layout_width="@dimen/login_cts_logo_width"
                android:layout_height="@dimen/login_cts_logo_height"
                android:src="@drawable/logo_cts_main"
                android:scaleType="fitCenter"
                android:contentDescription="CTS" />
        </LinearLayout>

        <!-- Divider under header -->
        <!-- Removed loginHeaderDivider -->

        <!-- ══ HERO SECTION ════════════════════════════════════════════════ -->
        <!-- PTIT Logo big - editorial hero -->
        <ImageView
            android:id="@+id/ivLoginHero"
            android:layout_width="@dimen/login_hero_size"
            android:layout_height="@dimen/login_hero_size"
            android:src="@drawable/logo_ptit"
            android:scaleType="fitCenter"
            android:layout_marginTop="@dimen/space_hero_top"
            app:layout_constraintTop_toBottomOf="@id/loginBrandHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Display headline (Nike Futura style) -->
        <TextView
            android:id="@+id/tvLoginHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHÀO MỪNG\nBẠN TRỞ LẠI"
            android:textSize="@dimen/text_login_headline"
            android:textColor="#111111"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingMultiplier="0.95"
            android:letterSpacing="0.02"
            android:layout_marginTop="@dimen/space_l"
            app:layout_constraintTop_toBottomOf="@id/ivLoginHero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvLoginSubheadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập để tiếp tục sử dụng PTalk"
            android:textSize="@dimen/text_login_subheadline"
            android:textColor="#707072"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_s"
            android:paddingStart="@dimen/subheadline_padding_h"
            android:paddingEnd="@dimen/subheadline_padding_h"
            app:layout_constraintTop_toBottomOf="@id/tvLoginHeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ FORM CARD ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/loginFormCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/space_xxl"
            android:layout_marginStart="@dimen/form_margin_h"
            android:layout_marginEnd="@dimen/form_margin_h"
            app:layout_constraintTop_toBottomOf="@id/tvLoginSubheadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Username label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÊN ĐĂNG NHẬP"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginBottom="@dimen/space_xs" />

            <!-- Username input -->
            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Nhập tên đăng nhập..."
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="text"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MẬT KHẨU"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_xs" />

            <!-- Password input -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Nhập mật khẩu..."
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="textPassword"
                android:importantForAutofill="no"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <!-- Error text (hidden by default) -->
            <TextView
                android:id="@+id/tvLoginError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_login_error"
                android:textColor="#D30005"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_s"
                android:visibility="gone" />

            <!-- Privacy & Terms Agreement Checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_l">

                <CheckBox
                    android:id="@+id/cbAgreeTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:buttonTint="#111111" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="I agree to "
                    android:textSize="@dimen/text_login_label"
                    android:textColor="#111111"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="@dimen/space_xs" />

                <TextView
                    android:id="@+id/tvPrivacyPolicy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy Policy"
                    android:textSize="@dimen/text_login_label"
                    android:textColor="#0066CC"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/space_xs"
                    android:paddingEnd="@dimen/space_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" and "
                    android:textSize="@dimen/text_login_label"
                    android:textColor="#111111"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/tvTermsConditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terms"
                    android:textSize="@dimen/text_login_label"
                    android:textColor="#0066CC"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="@dimen/space_xs"
                    android:paddingEnd="@dimen/space_xs" />
            </LinearLayout>

            <!-- Error message for unchecked terms -->
            <TextView
                android:id="@+id/tvTermsError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You must agree to Privacy Policy and Terms & Conditions"
                android:textSize="@dimen/text_login_error"
                android:textColor="#D30005"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_xs"
                android:visibility="gone" />

            <!-- Login button (Nike Black pill) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="ĐĂNG NHẬP"
                android:textSize="@dimen/text_login_button"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_login_button"
                android:layout_marginTop="@dimen/space_xl"
                android:elevation="2dp" />

            <!-- Divider with text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_xl">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E5E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  hoặc  "
                    android:textSize="@dimen/text_login_footer"
                    android:textColor="#9E9EA0"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E5E5" />
            </LinearLayout>

            <!-- Guest button (outlined pill) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuest"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="VÀO XEM THỬ"
                android:textSize="@dimen/text_guest_button"
                android:textColor="#111111"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:background="@drawable/bg_guest_button"
                android:layout_marginTop="@dimen/space_m" />

        </LinearLayout>

        <!-- ══ BOTTOM FOOTER ════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvLoginFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="© 2025 Lab CTS · Học viện Bưu chính Viễn thông PTIT\nMọi quyền được bảo lưu."
            android:textSize="@dimen/text_login_footer"
            android:textColor="#9E9EA0"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="@dimen/space_footer_top"
            android:layout_marginBottom="@dimen/space_footer_bottom"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h"
            app:layout_constraintTop_toBottomOf="@id/loginFormCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
