<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/login_min_height">

        <!-- ══ TOP RED ACCENT LINE ═════════════════════════════════════════ -->
        <!-- Removed loginAccentLine for cleaner glassy look -->

        <!-- ══ BRAND HEADER ════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/loginBrandHeader"
            android:layout_width="0dp"
            android:layout_height="@dimen/login_header_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h"
            android:layout_marginStart="@dimen/space_l"
            android:layout_marginEnd="@dimen/space_l"
            android:layout_marginTop="@dimen/space_l"
            android:background="@drawable/bg_glass_header"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- PTIT Logo left -->
            <ImageView
                android:layout_width="@dimen/login_ptit_logo_size"
                android:layout_height="@dimen/login_cts_logo_height"
                android:src="@drawable/logo_ptit"
                android:scaleType="fitCenter"
                android:contentDescription="PTIT" />

            <!-- Separator -->
            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/login_header_separator_height"
                android:background="@color/outline_soft"
                android:layout_marginStart="@dimen/login_header_separator_margin"
                android:layout_marginEnd="@dimen/login_header_separator_margin" />

            <!-- App name block — centered between two separators (KidMentor style) -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PTALK"
                android:gravity="center"
                android:textSize="@dimen/text_login_header_title"
                android:textColor="@color/color_login_headline"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06" />

            <!-- Separator -->
            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/login_header_separator_height"
                android:background="@color/outline_soft"
                android:layout_marginStart="@dimen/login_header_separator_margin"
                android:layout_marginEnd="@dimen/login_header_separator_margin" />

            <!-- CTS Logo right -->
            <ImageView
                android:layout_width="@dimen/login_cts_logo_width"
                android:layout_height="@dimen/login_cts_logo_height"
                android:src="@drawable/logo_cts_main"
                android:scaleType="fitCenter"
                android:contentDescription="CTS" />
        </LinearLayout>

        <!-- Divider under header -->
        <!-- Removed loginHeaderDivider -->

        <!-- ══ HERO SECTION ════════════════════════════════════════════════ -->
        <!-- Soft circular halo ring behind the mascot (matches KidMentor avatar) -->
        <View
            android:id="@+id/viewHeroHalo"
            android:layout_width="@dimen/login_hero_halo_size"
            android:layout_height="@dimen/login_hero_halo_size"
            android:background="@drawable/bg_hero_halo"
            android:layout_marginTop="@dimen/space_hero_top"
            app:layout_constraintTop_toBottomOf="@id/loginBrandHeader"
            app:layout_constraintBottom_toTopOf="@id/tvLoginHeadline"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Friendly mascot hero -->
        <ImageView
            android:id="@+id/ivLoginHero"
            android:layout_width="@dimen/login_hero_size"
            android:layout_height="@dimen/login_hero_size"
            android:src="@drawable/char_idle"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            app:layout_constraintTop_toTopOf="@id/viewHeroHalo"
            app:layout_constraintBottom_toBottomOf="@id/viewHeroHalo"
            app:layout_constraintStart_toStartOf="@id/viewHeroHalo"
            app:layout_constraintEnd_toEndOf="@id/viewHeroHalo" />

        <!-- Display headline (Nike Futura style) -->
        <TextView
            android:id="@+id/tvLoginHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_headline"
            android:textSize="@dimen/text_login_headline"
            android:textColor="@color/color_login_headline"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.05"
            android:letterSpacing="0.02"
            android:layout_marginTop="@dimen/space_l"
            app:layout_constraintTop_toBottomOf="@id/viewHeroHalo"
            app:layout_constraintBottom_toTopOf="@id/tvLoginSubheadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvLoginSubheadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subheadline"
            android:textSize="@dimen/text_login_subheadline"
            android:textColor="@color/color_login_subheadline"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_s"
            android:paddingStart="@dimen/subheadline_padding_h"
            android:paddingEnd="@dimen/subheadline_padding_h"
            app:layout_constraintTop_toBottomOf="@id/tvLoginHeadline"
            app:layout_constraintBottom_toTopOf="@id/loginFormCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ FORM CARD ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/loginFormCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_form_card"
            android:padding="20dp"
            android:elevation="3dp"
            android:layout_marginTop="@dimen/space_xl"
            android:layout_marginStart="@dimen/form_margin_h"
            android:layout_marginEnd="@dimen/form_margin_h"
            app:layout_constraintTop_toBottomOf="@id/tvLoginSubheadline"
            app:layout_constraintBottom_toTopOf="@id/tvLoginFooter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Error text (hidden by default) -->
            <TextView
                android:id="@+id/tvLoginError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_login_error"
                android:textColor="@color/color_login_error"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_s"
                android:visibility="gone" />

            <!-- Privacy & Terms consent — inline clickable links (text set in LoginActivity) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginTop="@dimen/space_l">

                <CheckBox
                    android:id="@+id/cbAgreeTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:buttonTint="@color/color_login_headline" />

                <TextView
                    android:id="@+id/tvConsent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_s"
                    android:textSize="@dimen/text_login_label"
                    android:textColor="@color/color_login_subheadline"
                    android:fontFamily="sans-serif"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Consent error (shown while unchecked) -->
            <TextView
                android:id="@+id/tvTermsError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_error"
                android:textSize="@dimen/text_login_error"
                android:textColor="@color/color_login_error"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_xs"
                android:visibility="gone" />

            <!-- SSO login button (black pill, key icon grouped with the centered label) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="@string/login_btn_text"
                android:textSize="@dimen/text_login_button"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginTop="@dimen/space_xl"
                app:backgroundTint="@color/btn_primary_bg"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_key"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconSize="20dp"
                app:iconTint="#FFFFFF" />

            <!-- Divider with text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/space_xl">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/color_login_divider_line" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_or"
                    android:paddingStart="@dimen/space_m"
                    android:paddingEnd="@dimen/space_m"
                    android:textSize="@dimen/text_login_footer"
                    android:textColor="@color/color_login_footer"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/color_login_divider_line" />
            </LinearLayout>

            <!-- Guest button (outlined pill) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGuest"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="@string/login_guest_btn_text"
                android:textSize="@dimen/text_guest_button"
                android:textColor="@color/color_login_headline"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:background="@drawable/bg_guest_button"
                android:layout_marginTop="@dimen/space_m" />

        </LinearLayout>

        <!-- ══ BOTTOM FOOTER ════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvLoginFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/login_footer"
            android:textSize="@dimen/text_login_footer"
            android:textColor="@color/color_login_footer"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="@dimen/space_footer_top"
            android:layout_marginBottom="@dimen/space_footer_bottom"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
