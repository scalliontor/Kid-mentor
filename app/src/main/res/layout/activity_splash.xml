<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ══ HERO LOGO (new P-Talk Signature badge, rounded floating card) ═══ -->
    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:src="@drawable/logo_ptalk_signature"
        android:background="@drawable/bg_splash_logo"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:elevation="14dp"
        android:alpha="0"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.40"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline (logo already carries the name) -->
    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đồng hành cùng trẻ em &amp; người cao tuổi"
        android:textSize="@dimen/text_splash_subtitle"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.03"
        android:gravity="center"
        android:alpha="0"
        android:layout_marginTop="@dimen/space_xl"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        app:layout_constraintTop_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Kept for animation compatibility (hidden) -->
    <TextView
        android:id="@+id/tvMadeBy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CTS co-brand logo -->
    <ImageView
        android:id="@+id/ivSplashLogoCts"
        android:layout_width="@dimen/splash_cts_logo_width"
        android:layout_height="@dimen/splash_cts_logo_height"
        android:src="@drawable/logo_cts_flashscreen"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:layout_marginTop="@dimen/space_l"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom divider -->
    <View
        android:id="@+id/bottomDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_login_divider_line"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="@dimen/space_bottom_divider_margin"
        app:layout_constraintBottom_toTopOf="@id/tvSplashFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSplashFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Học viện Công nghệ Bưu chính Viễn thông"
        android:textSize="@dimen/text_splash_footer"
        android:textColor="@color/text_muted"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="@dimen/space_footer_margin_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
