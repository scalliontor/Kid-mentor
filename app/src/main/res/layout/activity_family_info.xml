<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerFamily"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#222222"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/family_header"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111111" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerFamily"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <!-- ── Phụ huynh ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/family_parent_section"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.05"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardParent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Họ tên -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/family_label_fullname"
                        android:textSize="12sp"
                        android:textColor="#9E9EA0"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvParentName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/family_value_placeholder"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="14dp" />

                    <!-- Ngày sinh -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/family_label_dob"
                        android:textSize="12sp"
                        android:textColor="#9E9EA0"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvParentDob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/family_value_placeholder"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="14dp" />

                    <!-- SĐT -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/family_label_phone"
                        android:textSize="12sp"
                        android:textColor="#9E9EA0"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvParentPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/family_value_placeholder"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="14dp" />

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/family_label_email"
                        android:textSize="12sp"
                        android:textColor="#9E9EA0"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvParentEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/family_value_placeholder"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Con ──────────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/family_children_section"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.05"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="8dp" />

            <!-- Children cards are inflated programmatically into this container -->
            <LinearLayout
                android:id="@+id/containerChildren"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty state (hidden by default) -->
            <TextView
                android:id="@+id/tvChildrenEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/family_children_empty"
                android:textSize="14sp"
                android:textColor="#9E9EA0"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:visibility="gone" />

            <!-- Error text (hidden by default) -->
            <TextView
                android:id="@+id/tvFamilyError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#D30005"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressFamily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
