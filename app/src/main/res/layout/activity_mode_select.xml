<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/modeSelectRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ══ BRAND HEADER (same glassy bar as other screens) ═══════════════ -->
    <!-- ══ BRAND HEADER (same glassy bar as other screens) ═══════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/modeSelectHeader"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:paddingStart="@dimen/login_header_padding_h"
        android:paddingEnd="@dimen/login_header_padding_h"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PTIT Logo -->
        <ImageView
            android:id="@+id/ivModePtit"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logo_ptit"
            android:scaleType="fitCenter"
            android:contentDescription="PTIT"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- App name (Centered) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PTALK"
                android:textSize="@dimen/text_login_header_title"
                android:textColor="#111111"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <!-- CTS Logo -->
        <ImageView
            android:layout_width="@dimen/login_cts_logo_width"
            android:layout_height="@dimen/login_cts_logo_height"
            android:src="@drawable/logo_cts_main"
            android:scaleType="fitCenter"
            android:contentDescription="CTS"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══ HEADLINE ══════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvModeHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHỌN CHẾ ĐỘ"
        android:textSize="28sp"
        android:textColor="#111111"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        android:layout_marginTop="@dimen/space_hero_top"
        app:layout_constraintTop_toBottomOf="@id/modeSelectHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/btnProfile"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_menu_hamburger"
        android:tint="#333333"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/tvModeHeadline"
        app:layout_constraintBottom_toBottomOf="@id/tvModeHeadline"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvModeSubheadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vui lòng chọn một chế độ để tiếp tục"
        android:textSize="14sp"
        android:textColor="#707072"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginTop="@dimen/space_s"
        app:layout_constraintTop_toBottomOf="@id/tvModeHeadline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ MODE CARDS ════════════════════════════════════════════════════ -->

    <!-- KID MENTOR Card -->
    <LinearLayout
        android:id="@+id/cardKidMentor"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_mode_card_kid"
        android:padding="@dimen/space_xl"
        android:layout_marginStart="@dimen/form_margin_h"
        android:layout_marginEnd="@dimen/space_m"
        android:layout_marginTop="@dimen/space_xxl"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/tvModeSubheadline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardElderCare">

        <!-- Kid character icon -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/char_idle1"
            android:scaleType="fitCenter"
            android:contentDescription="Kid Mentor" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KID MENTOR"
            android:textSize="16sp"
            android:textColor="#2E7D52"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:layout_marginTop="@dimen/space_m" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trợ lý học tập"
            android:textSize="12sp"
            android:textColor="#707072"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_xs" />
    </LinearLayout>

    <!-- ELDER CARE Card -->
    <LinearLayout
        android:id="@+id/cardElderCare"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_mode_card_elder"
        android:padding="@dimen/space_xl"
        android:layout_marginStart="@dimen/space_m"
        android:layout_marginEnd="@dimen/form_margin_h"
        android:layout_marginTop="@dimen/space_xxl"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/tvModeSubheadline"
        app:layout_constraintStart_toEndOf="@id/cardKidMentor"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Elder care icon — reuse thinking character or a different image -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/char_talking_2"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:contentDescription="Elder Care" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ELDER CARE"
            android:textSize="16sp"
            android:textColor="#D35400"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:layout_marginTop="@dimen/space_m" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trợ lý sức khoẻ"
            android:textSize="12sp"
            android:textColor="#707072"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_xs" />
    </LinearLayout>

    <!-- ══ FOOTER ═══════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvModeFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="© 2025 Lab CTS · Học viện Bưu chính Viễn thông PTIT"
        android:textSize="@dimen/text_login_footer"
        android:textColor="#9E9EA0"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginBottom="@dimen/space_footer_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
