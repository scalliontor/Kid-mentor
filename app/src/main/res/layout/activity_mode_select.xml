<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/modeSelectRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_mode_select">

    <!-- ══ DECORATIVE ATMOSPHERE BLOBS (behind everything) ═══════════════ -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_blob_kid"
        android:layout_marginStart="-90dp"
        android:layout_marginTop="-40dp"
        app:layout_constraintTop_toBottomOf="@id/modeSelectHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/bg_blob_elder"
        android:layout_marginEnd="-110dp"
        android:layout_marginBottom="-60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ BRAND HEADER (same glassy bar as other screens) ═══════════════ -->
    <LinearLayout
        android:id="@+id/modeSelectHeader"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/login_header_padding_h"
        android:paddingEnd="@dimen/login_header_padding_h"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PTIT Logo -->
        <ImageView
            android:layout_width="@dimen/brand_ptit_size"
            android:layout_height="@dimen/brand_ptit_size"
            android:src="@drawable/logo_ptit"
            android:scaleType="fitCenter"
            android:contentDescription="PTIT" />

        <!-- Separator -->
        <View
            android:layout_width="1dp"
            android:layout_height="@dimen/brand_separator_height"
            android:background="@color/outline_soft"
            android:layout_marginStart="@dimen/login_header_separator_margin"
            android:layout_marginEnd="@dimen/login_header_separator_margin" />

        <!-- App name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PTALK AI"
                android:textSize="@dimen/text_login_header_title"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_institution"
                android:textSize="@dimen/text_brand_subtitle"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- CTS Logo -->
        <ImageView
            android:layout_width="@dimen/login_cts_logo_width"
            android:layout_height="@dimen/login_cts_logo_height"
            android:src="@drawable/logo_cts_main"
            android:scaleType="fitCenter"
            android:contentDescription="CTS" />

        <!-- Settings (global) -->
        <ImageView
            android:id="@+id/btnModeSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:tint="@color/icon_neutral"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="@dimen/space_s"
            android:contentDescription="@string/cd_settings" />
    </LinearLayout>

    <!-- ══ HEADLINE ══════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvModeHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_select_headline"
        android:textSize="28sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        android:layout_marginTop="@dimen/space_hero_top"
        app:layout_constraintTop_toBottomOf="@id/modeSelectHeader"
        app:layout_constraintBottom_toTopOf="@id/tvModeSubheadline"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvModeSubheadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_select_subheadline"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginTop="@dimen/space_s"
        app:layout_constraintTop_toBottomOf="@id/tvModeHeadline"
        app:layout_constraintBottom_toTopOf="@id/modeCardsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ MODE CARDS (equal-height row) ═════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/modeCardsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginStart="@dimen/form_margin_h"
        android:layout_marginEnd="@dimen/form_margin_h"
        android:layout_marginTop="@dimen/space_xl"
        app:layout_constraintTop_toBottomOf="@id/tvModeSubheadline"
        app:layout_constraintBottom_toTopOf="@id/tvModeHelper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ───────── KID MENTOR Card ───────── -->
        <LinearLayout
            android:id="@+id/cardKidMentor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/space_m"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_mode_card_kid"
            android:padding="@dimen/space_xl"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Audience badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_kid_badge"
                android:textSize="10sp"
                android:textColor="@color/accent_kid_dark"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_badge_kid"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />

            <!-- Character inside soft halo -->
            <ImageView
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:background="@drawable/bg_icon_halo_kid"
                android:padding="14dp"
                android:src="@drawable/mode_logo_kid"
                android:scaleType="fitCenter"
                android:layout_marginTop="@dimen/space_l"
                android:contentDescription="Kid Mentor" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_kid_mentor"
                android:textSize="17sp"
                android:textColor="@color/accent_kid_dark"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:layout_marginTop="@dimen/space_m" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_kid_desc"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_xs" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_subtle"
                android:layout_marginTop="@dimen/space_l" />

            <!-- Feature list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/space_l">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_kid_feat1"
                    android:textSize="12.5sp"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/accent_kid"
                    android:drawablePadding="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_kid_feat2"
                    android:textSize="12.5sp"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/accent_kid"
                    android:drawablePadding="10dp"
                    android:layout_marginTop="@dimen/space_m" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_kid_feat3"
                    android:textSize="12.5sp"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/accent_kid"
                    android:drawablePadding="10dp"
                    android:layout_marginTop="@dimen/space_m" />
            </LinearLayout>

            <!-- spacer pushes CTA to the bottom so both cards align -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- CTA pill -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_kid_cta"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:background="@drawable/bg_cta_kid"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical"
                android:drawableEnd="@drawable/ic_arrow_forward"
                android:drawableTint="#FFFFFF"
                android:drawablePadding="8dp"
                android:layout_marginTop="@dimen/space_xl" />
        </LinearLayout>

        <!-- ───────── ELDER CARE Card ───────── -->
        <LinearLayout
            android:id="@+id/cardElderCare"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_m"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_mode_card_elder"
            android:padding="@dimen/space_xl"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Audience badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_elder_badge"
                android:textSize="10sp"
                android:textColor="@color/accent_elder_dark"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_badge_elder"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />

            <!-- Character inside soft halo -->
            <ImageView
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:background="@drawable/bg_icon_halo_elder"
                android:padding="14dp"
                android:src="@drawable/mode_logo_elder"
                android:scaleType="fitCenter"
                android:layout_marginTop="@dimen/space_l"
                android:contentDescription="Elder Care" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_elder_care"
                android:textSize="17sp"
                android:textColor="@color/accent_elder_dark"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:layout_marginTop="@dimen/space_m" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_elder_desc"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_xs" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_subtle"
                android:layout_marginTop="@dimen/space_l" />

            <!-- Feature list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/space_l">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_elder_feat1"
                    android:textSize="12.5sp"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/accent_elder"
                    android:drawablePadding="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_elder_feat2"
                    android:textSize="12.5sp"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/accent_elder"
                    android:drawablePadding="10dp"
                    android:layout_marginTop="@dimen/space_m" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_elder_feat3"
                    android:textSize="12.5sp"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/accent_elder"
                    android:drawablePadding="10dp"
                    android:layout_marginTop="@dimen/space_m" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- CTA pill -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_elder_cta"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:background="@drawable/bg_cta_elder"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical"
                android:drawableEnd="@drawable/ic_arrow_forward"
                android:drawableTint="#FFFFFF"
                android:drawablePadding="8dp"
                android:layout_marginTop="@dimen/space_xl" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══ HELPER NOTE ══════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvModeHelper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_select_helper"
        android:textSize="12sp"
        android:textColor="@color/text_muted"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginTop="@dimen/space_l"
        app:layout_constraintTop_toBottomOf="@id/modeCardsRow"
        app:layout_constraintBottom_toTopOf="@id/tvModeFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ FOOTER ═══════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvModeFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/footer_copyright"
        android:textSize="@dimen/text_login_footer"
        android:textColor="@color/text_muted"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:layout_marginBottom="@dimen/space_footer_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
