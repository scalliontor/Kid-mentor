<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/subRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="28dp">

        <!-- Top bar: back + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="←"
                android:textSize="26sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sub_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"
                android:textColor="@color/text_primary"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_intro"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="20dp" />

        <!-- Segmented plan selector -->
        <LinearLayout
            android:id="@+id/planTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_plan_track"
            android:padding="5dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/tabPlanBasic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/plan_basic"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tabPlanPro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/plan_pro"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tabPlanUltra"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/plan_ultra"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Selected-plan detail card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_form_card"
            android:padding="24dp"
            android:elevation="6dp">

            <!-- Plan name + badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPlanName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvPlanBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:textColor="@color/accent_elder_dark"
                    android:background="@drawable/bg_plan_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Price block -->
            <TextView
                android:id="@+id/tvPlanPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:layout_marginTop="14dp" />

            <!-- Quota row (label + value) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_quota_label"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/tvPlanQuota"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_body"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_subtle"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="16dp" />

            <!-- Benefits -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sub_benefits_label"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sub_feat_voice"
                android:textSize="14sp"
                android:textColor="@color/text_body"
                android:fontFamily="sans-serif"
                android:gravity="center_vertical"
                android:drawableStart="@drawable/ic_check"
                android:drawableTint="@color/accent_kid"
                android:drawablePadding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sub_feat_fast"
                android:textSize="14sp"
                android:textColor="@color/text_body"
                android:fontFamily="sans-serif"
                android:gravity="center_vertical"
                android:drawableStart="@drawable/ic_check"
                android:drawableTint="@color/accent_kid"
                android:drawablePadding="12dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sub_feat_history"
                android:textSize="14sp"
                android:textColor="@color/text_body"
                android:fontFamily="sans-serif"
                android:gravity="center_vertical"
                android:drawableStart="@drawable/ic_check"
                android:drawableTint="@color/accent_kid"
                android:drawablePadding="12dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sub_feat_modes"
                android:textSize="14sp"
                android:textColor="@color/text_body"
                android:fontFamily="sans-serif"
                android:gravity="center_vertical"
                android:drawableStart="@drawable/ic_check"
                android:drawableTint="@color/accent_kid"
                android:drawablePadding="12dp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnPlanAction"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:letterSpacing="0.02"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sub_footer"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:fontFamily="sans-serif"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:layout_marginTop="22dp" />
    </LinearLayout>
</ScrollView>
