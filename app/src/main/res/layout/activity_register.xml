<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        android:minHeight="@dimen/login_min_height">

        <!-- ══ HERO SECTION ════════════════════════════════════════════════ -->
        <ImageView
            android:id="@+id/ivRegisterHero"
            android:layout_width="@dimen/login_hero_size"
            android:layout_height="@dimen/login_hero_size"
            android:src="@drawable/logo_ptit"
            android:scaleType="fitCenter"
            android:layout_marginTop="@dimen/space_hero_top"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Headline -->
        <TextView
            android:id="@+id/tvRegisterHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_headline"
            android:textSize="@dimen/text_login_headline"
            android:textColor="#111111"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingMultiplier="0.95"
            android:letterSpacing="0.02"
            android:layout_marginTop="@dimen/space_l"
            app:layout_constraintTop_toBottomOf="@id/ivRegisterHero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvRegisterSubheadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_subheadline"
            android:textSize="@dimen/text_login_subheadline"
            android:textColor="#707072"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_s"
            android:paddingStart="@dimen/subheadline_padding_h"
            android:paddingEnd="@dimen/subheadline_padding_h"
            app:layout_constraintTop_toBottomOf="@id/tvRegisterHeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ FORM CARD ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/registerFormCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/space_xxl"
            android:layout_marginStart="@dimen/form_margin_h"
            android:layout_marginEnd="@dimen/form_margin_h"
            app:layout_constraintTop_toBottomOf="@id/tvRegisterSubheadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Username label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_username_label"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginBottom="@dimen/space_xs" />

            <EditText
                android:id="@+id/etRegUsername"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/register_username_hint"
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="text"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_email_label"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_xs" />

            <EditText
                android:id="@+id/etRegEmail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/register_email_hint"
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="textEmailAddress"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_password_label"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_xs" />

            <EditText
                android:id="@+id/etRegPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/register_password_hint"
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="textPassword"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Confirm password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_confirm_label"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_xs" />

            <EditText
                android:id="@+id/etRegConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/register_confirm_hint"
                android:textSize="@dimen/text_input"
                android:textColor="#111111"
                android:textColorHint="#9E9EA0"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_input_field"
                android:paddingStart="@dimen/input_padding_h"
                android:paddingEnd="@dimen/input_padding_h"
                android:inputType="textPassword"
                android:importantForAutofill="no"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <!-- Error text -->
            <TextView
                android:id="@+id/tvRegisterError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_login_error"
                android:textColor="#D30005"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_s"
                android:visibility="gone" />

            <!-- Success text -->
            <TextView
                android:id="@+id/tvRegisterSuccess"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_login_error"
                android:textColor="#16A34A"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/space_s"
                android:visibility="gone" />

            <!-- Register button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="@string/register_btn_text"
                android:textSize="@dimen/text_login_button"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_login_button"
                android:layout_marginTop="@dimen/space_xl"
                android:elevation="2dp" />

            <!-- Login link -->
            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/register_login_link"
                android:textSize="@dimen/text_login_label"
                android:textColor="#2563EB"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ══ BOTTOM FOOTER ════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvRegisterFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/login_footer"
            android:textSize="@dimen/text_login_footer"
            android:textColor="#9E9EA0"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="@dimen/space_footer_top"
            android:layout_marginBottom="@dimen/space_footer_bottom"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h"
            app:layout_constraintTop_toBottomOf="@id/registerFormCard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
