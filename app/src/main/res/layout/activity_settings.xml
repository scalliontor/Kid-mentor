<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mode_select"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/space_xxl">

        <!-- ══ HEADER (glass pill: back · title · CTS) ═══════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/brand_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_s"
            android:paddingEnd="@dimen/login_header_padding_h"
            android:layout_marginStart="@dimen/space_l"
            android:layout_marginEnd="@dimen/space_l"
            android:layout_marginTop="@dimen/space_l"
            android:background="@drawable/bg_glass_header"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/btnSettingsBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="9dp"
                android:tint="@color/icon_neutral"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back_to_mode_select" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:layout_marginStart="@dimen/space_s" />

            <ImageView
                android:layout_width="@dimen/login_cts_logo_width"
                android:layout_height="@dimen/login_cts_logo_height"
                android:src="@drawable/logo_cts_main"
                android:scaleType="fitCenter"
                android:contentDescription="CTS" />
        </LinearLayout>

        <!-- ══ SECTION · TÀI KHOẢN ══════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvSectionAccount"
            style="@style/SettingsSectionLabel"
            android:text="@string/settings_section_account" />

        <LinearLayout
            style="@style/SettingsCard">

            <!-- User identity row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:id="@+id/ivAccountAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="10dp"
                    android:src="@drawable/ic_account"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/settings_section_account" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tvAccountName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_guest_name"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvAccountSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_guest_sub"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <!-- Account info row (read-only parent + children) · KID_MENTOR only -->
            <LinearLayout
                android:id="@+id/rowAccountInfo"
                style="@style/SettingsRow"
                android:visibility="gone">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/settings_account_info" />

                <ImageView
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View
                android:id="@+id/dividerAccountInfo"
                style="@style/SettingsDivider"
                android:visibility="gone" />

            <!-- Subscription row -->
            <LinearLayout
                android:id="@+id/rowSubscription"
                style="@style/SettingsRow">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/settings_subscription" />

                <ImageView
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION · GIAO DIỆN (Sáng / Tối / Hệ thống) ══════════════ -->
        <TextView
            android:id="@+id/tvSectionTheme"
            style="@style/SettingsSectionLabel"
            android:text="@string/settings_section_theme" />

        <LinearLayout style="@style/SettingsCard">

            <LinearLayout
                android:id="@+id/rowThemeLight"
                style="@style/SettingsRow">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sun"
                    android:tint="@color/icon_neutral"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/theme_light" />
                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_marginStart="14dp"
                    android:text="@string/theme_light" />
                <ImageView
                    android:id="@+id/checkThemeLight"
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_check"
                    android:tint="@color/accent_kid_dark"
                    android:visibility="invisible"
                    android:contentDescription="@string/theme_light" />
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/rowThemeDark"
                style="@style/SettingsRow">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_moon"
                    android:tint="@color/icon_neutral"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/theme_dark" />
                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_marginStart="14dp"
                    android:text="@string/theme_dark" />
                <ImageView
                    android:id="@+id/checkThemeDark"
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_check"
                    android:tint="@color/accent_kid_dark"
                    android:visibility="invisible"
                    android:contentDescription="@string/theme_dark" />
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/rowThemeSystem"
                style="@style/SettingsRow">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_theme_auto"
                    android:tint="@color/icon_neutral"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/theme_system" />
                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_marginStart="14dp"
                    android:text="@string/theme_system" />
                <ImageView
                    android:id="@+id/checkThemeSystem"
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_check"
                    android:tint="@color/accent_kid_dark"
                    android:visibility="invisible"
                    android:contentDescription="@string/theme_system" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION · NGÔN NGỮ (Theo hệ thống / Tiếng Việt / English) ═ -->
        <TextView
            android:id="@+id/tvSectionLanguage"
            style="@style/SettingsSectionLabel"
            android:text="@string/settings_section_language" />

        <LinearLayout style="@style/SettingsCard">

            <LinearLayout
                android:id="@+id/rowLangSystem"
                style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/lang_system" />
                <ImageView
                    android:id="@+id/checkLangSystem"
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_check"
                    android:tint="@color/accent_kid_dark"
                    android:visibility="invisible"
                    android:contentDescription="@string/lang_system" />
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/rowLangVietnamese"
                style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/lang_vietnamese" />
                <ImageView
                    android:id="@+id/checkLangVietnamese"
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_check"
                    android:tint="@color/accent_kid_dark"
                    android:visibility="invisible"
                    android:contentDescription="@string/lang_vietnamese" />
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/rowLangEnglish"
                style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/lang_english" />
                <ImageView
                    android:id="@+id/checkLangEnglish"
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_check"
                    android:tint="@color/accent_kid_dark"
                    android:visibility="invisible"
                    android:contentDescription="@string/lang_english" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION · ELDER CARE (hiển thị theo chế độ) ══════════════ -->
        <TextView
            android:id="@+id/tvSectionElder"
            style="@style/SettingsSectionLabel"
            android:text="@string/settings_section_elder"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/cardElderSettings"
            style="@style/SettingsCard"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_emergency_label"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" />

                <EditText
                    android:id="@+id/etEmergencyNumber"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:inputType="phone"
                    android:maxLength="15"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:imeOptions="actionDone"
                    android:layout_marginTop="8dp"
                    android:autofillHints="phone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_emergency_hint"
                    android:textSize="11.5sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION · VỀ ỨNG DỤNG ════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvSectionAbout"
            style="@style/SettingsSectionLabel"
            android:text="@string/settings_section_about" />

        <LinearLayout
            style="@style/SettingsCard">

            <LinearLayout
                android:id="@+id/rowPrivacy"
                style="@style/SettingsRow">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/settings_privacy" />

                <ImageView
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                android:id="@+id/rowTerms"
                style="@style/SettingsRow">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/settings_terms" />

                <ImageView
                    style="@style/SettingsChevron"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View style="@style/SettingsDivider" />

            <LinearLayout
                style="@style/SettingsRow"
                android:clickable="false"
                android:focusable="false"
                android:background="@null">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:text="@string/settings_version" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ AUTH ACTION (Đăng xuất / Đăng nhập) ══════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAuthAction"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:text="@string/settings_logout"
            android:textSize="@dimen/text_login_button"
            android:textColor="#D30005"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="@dimen/form_margin_h"
            android:layout_marginEnd="@dimen/form_margin_h"
            android:layout_marginTop="@dimen/space_xxl"
            app:cornerRadius="27dp"
            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="20dp"
            app:iconTint="#D30005" />

        <!-- ══ FOOTER ════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/footer_copyright"
            android:textSize="@dimen/text_login_footer"
            android:textColor="@color/text_muted"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_xl"
            android:paddingStart="@dimen/login_header_padding_h"
            android:paddingEnd="@dimen/login_header_padding_h" />

    </LinearLayout>
</ScrollView>
