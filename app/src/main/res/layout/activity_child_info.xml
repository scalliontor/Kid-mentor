<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:id="@+id/headerChild"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#222222"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/tvChildHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/child_header"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111111" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerChild"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/form_margin_h"
            android:paddingEnd="@dimen/form_margin_h"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/child_subtitle"
                android:textSize="@dimen/text_login_subheadline"
                android:textColor="#707072"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Tên bé -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_name_label"
                        android:textSize="@dimen/text_login_label"
                        android:textColor="#707072"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <EditText
                        android:id="@+id/etChildName"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/child_name_hint"
                        android:textSize="@dimen/text_input"
                        android:textColor="#111111"
                        android:textColorHint="#9E9EA0"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:inputType="textPersonName|textCapWords"
                        android:importantForAutofill="no"
                        android:imeOptions="actionNext"
                        android:singleLine="true" />

                    <!-- Lớp -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/student_grade_label"
                        android:textSize="@dimen/text_login_label"
                        android:textColor="#707072"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginTop="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <EditText
                        android:id="@+id/etChildGrade"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/student_grade_hint"
                        android:textSize="@dimen/text_input"
                        android:textColor="#111111"
                        android:textColorHint="#9E9EA0"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none"
                        android:importantForAutofill="no"
                        android:singleLine="true" />

                    <!-- Ngày sinh -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/student_dob_label"
                        android:textSize="@dimen/text_login_label"
                        android:textColor="#707072"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginTop="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <EditText
                        android:id="@+id/etChildDob"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/student_dob_hint"
                        android:textSize="@dimen/text_input"
                        android:textColor="#111111"
                        android:textColorHint="#9E9EA0"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none"
                        android:importantForAutofill="no"
                        android:singleLine="true" />

                    <!-- Quê quán -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/student_hometown_label"
                        android:textSize="@dimen/text_login_label"
                        android:textColor="#707072"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginTop="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <EditText
                        android:id="@+id/etChildHometown"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/student_hometown_hint"
                        android:textSize="@dimen/text_input"
                        android:textColor="#111111"
                        android:textColorHint="#9E9EA0"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:inputType="textCapWords"
                        android:importantForAutofill="no"
                        android:imeOptions="actionNext"
                        android:singleLine="true" />

                    <!-- Bộ sách -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/student_curriculum_label"
                        android:textSize="@dimen/text_login_label"
                        android:textColor="#707072"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginTop="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <EditText
                        android:id="@+id/etChildCurriculum"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/student_curriculum_hint"
                        android:textSize="@dimen/text_input"
                        android:textColor="#111111"
                        android:textColorHint="#9E9EA0"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none"
                        android:importantForAutofill="no"
                        android:singleLine="true" />

                    <!-- Quan hệ với bé -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_relationship_label"
                        android:textSize="@dimen/text_login_label"
                        android:textColor="#707072"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:layout_marginTop="@dimen/space_l"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <EditText
                        android:id="@+id/etChildRelationship"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="@string/child_relationship_hint"
                        android:textSize="@dimen/text_input"
                        android:textColor="#111111"
                        android:textColorHint="#9E9EA0"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="@dimen/input_padding_h"
                        android:paddingEnd="@dimen/input_padding_h"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:inputType="none"
                        android:importantForAutofill="no"
                        android:singleLine="true" />

                    <TextView
                        android:id="@+id/tvChildError"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="@dimen/text_login_error"
                        android:textColor="#D30005"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="@dimen/space_s"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnChildSave"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:text="@string/child_save"
                android:textSize="@dimen/text_login_button"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_login_button"
                android:layout_marginTop="@dimen/space_xl"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/tvChildSkip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/student_skip"
                android:textSize="@dimen/text_login_label"
                android:textColor="#707072"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressChild"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_l"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
