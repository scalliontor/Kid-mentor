<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- ══ BACKGROUND EFFECTS ═══════════════════════════════════════════ -->
    <com.buivan.ptalk_child.StarFieldView
        android:id="@+id/bgStarField"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.buivan.ptalk_child.WaveView
        android:id="@+id/bgWaveEffect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BRAND BAR — PTIT + CTS logos (copyright / attribution strip)    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Removed brandAccentLine to use glassy header with margins -->

    <!-- Brand bar background (Glassy) -->
    <View
        android:id="@+id/brandBarBg"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Back button - below brand bar -->
    <ImageView
        android:id="@+id/btnBackMode"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@android:drawable/ic_menu_revert"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:tint="#222222"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivBrandPtitLeft"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/logo_ptit"
        android:scaleType="fitCenter"
        android:layout_marginStart="16dp"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg" />

    <!-- App name & institution -->
    <LinearLayout
        android:id="@+id/brandTextBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvBrandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PTALK"
            android:textSize="@dimen/text_brand_title"
            android:textColor="#111111"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06" />
    </LinearLayout>

    <!-- CTS Logo — right side -->
    <ImageView
        android:id="@+id/ivBrandCtsRight"
        android:layout_width="@dimen/brand_cts_width"
        android:layout_height="@dimen/brand_cts_height"
        android:src="@drawable/logo_cts_main"
        android:scaleType="fitCenter"
        android:layout_marginEnd="@dimen/brand_side_margin"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg" />

    <!-- Removed brandBarBottomLine for cleaner glassy look -->

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  GREETING TEXTS                                                    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xin chào!"
        android:textSize="@dimen/text_greeting"
        android:textColor="#6BAF8A"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnBackMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSTT"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="16dp"
        android:text="STT, công thức"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hôm nay, tớ có thể giúp gì cho cậu?"
        android:textSize="@dimen/text_sub_greeting"
        android:textStyle="bold"
        android:textColor="#2E7D52"
        android:gravity="center"
        android:layout_marginTop="@dimen/space_xs"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  WAVEFORM + CHARACTER (giữ nguyên thứ tự z-order gốc)            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- ① SÓNG ÂM — khai báo TRƯỚC ảnh để nằm phía sau -->
    <com.buivan.ptalk_child.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="@dimen/waveform_height"
        app:layout_constraintTop_toBottomOf="@id/tvSTT"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ② ẢNH NHÂN VẬT — khai báo SAU, nổi lên trên sóng -->
    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="@dimen/character_size"
        android:layout_height="@dimen/character_size"
        android:src="@drawable/char_idle1"
        android:scaleType="centerCrop"
        android:contentDescription="AI character"
        app:layout_constraintTop_toBottomOf="@id/tvSTT"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM CONTROLS                                                   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Text trạng thái -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chạm để ghi âm"
        android:textSize="@dimen/text_status"
        android:textColor="#8BAF9A"
        android:layout_marginBottom="@dimen/space_s"
        app:layout_constraintBottom_toTopOf="@id/btnCancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierBottomControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="btnHoldToTalk, containerElderButtons" />

    <!-- Nút cancel (chỉ hiện khi PLAYING) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCancel"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:text="⏹  DỪNG LẠI"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_cancel_button"
        android:visibility="gone"
        android:elevation="8dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/barrierBottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Bar Container for the curved look -->
    <View
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@drawable/bg_bottom_bar"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Left Button: Camera -->
    <LinearLayout
        android:id="@+id/btnCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnHoldToTalk"
        android:layout_marginBottom="12dp">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#333333" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera"
            android:textSize="12sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Right Button: Setting (or Record) -->
    <LinearLayout
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnHoldToTalk"
        android:layout_marginBottom="12dp">
        <ImageView
            android:id="@+id/ivSettingIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#333333" />
        <TextView
            android:id="@+id/tvSettingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setting"
            android:textSize="12sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Cancel Zone Shadow (Visible when recording in Kid Mentor) -->
    <View
        android:id="@+id/cancelZoneShadow"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_cancel_zone_ring"
        android:visibility="invisible"
        android:elevation="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nút mic hold to talk -->
    <ImageButton
        android:id="@+id/btnHoldToTalk"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_mic_custom"
        android:background="@drawable/bg_hold_button"
        android:scaleType="centerInside"
        android:padding="@dimen/btn_mic_padding"
        android:layout_marginBottom="@dimen/space_l"
        android:elevation="12dp"
        android:contentDescription="Ghi âm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ELDER CARE BUTTONS (Symmetric Camera and Mic) -->
    <LinearLayout
        android:id="@+id/containerElderButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <!-- Camera Button (Pastel Orange) -->
        <ImageButton
            android:id="@+id/btnCameraElder"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/bg_circle_orange_pastel"
            android:scaleType="centerInside"
            android:padding="20dp"
            android:elevation="8dp" />

        <!-- Swipe Path Indicator -->
        <LinearLayout
            android:id="@+id/swipePathElder"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="invisible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;&lt;&lt; Vuốt để huỷ"
                android:textColor="#FF5252"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Mic Button (Pastel Green) -->
        <ImageButton
            android:id="@+id/btnHoldToTalkElder"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_mic_custom"
            android:background="@drawable/bg_circle_green_pastel"
            android:scaleType="centerInside"
            android:padding="20dp"
            android:elevation="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
