<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- Subtle animated star background (declared first → drawn behind everything) -->
    <com.ctslab.ptalk_signature.StarFieldView
        android:id="@+id/starFieldView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BRAND BAR — PTIT + CTS logos (copyright / attribution strip)    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Removed brandAccentLine to use glassy header with margins -->

    <!-- Brand bar background (Glassy) -->
    <View
        android:id="@+id/brandBarBg"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PTIT Logo — left side -->
    <ImageView
        android:id="@+id/ivBrandPtitLeft"
        android:layout_width="@dimen/brand_ptit_size"
        android:layout_height="@dimen/brand_ptit_size"
        android:src="@drawable/logo_ptit"
        android:scaleType="fitCenter"
        android:layout_marginStart="@dimen/brand_side_margin"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg" />

    <!-- Vertical separator -->
    <View
        android:id="@+id/brandSeparator"
        android:layout_width="1dp"
        android:layout_height="@dimen/brand_separator_height"
        android:background="@color/outline_soft"
        android:layout_marginStart="@dimen/brand_separator_margin_start"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toEndOf="@id/ivBrandPtitLeft" />

    <!-- App name & institution -->
    <LinearLayout
        android:id="@+id/brandTextBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg">

        <TextView
            android:id="@+id/tvBrandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="P-Talk Signature"
            android:textSize="@dimen/text_brand_title"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06" />
    </LinearLayout>

    <!-- CTS Logo — right side -->
    <ImageView
        android:id="@+id/ivBrandCtsRight"
        android:layout_width="@dimen/brand_cts_width"
        android:layout_height="@dimen/brand_cts_height"
        android:src="@drawable/logo_cts_main"
        android:scaleType="fitCenter"
        android:layout_marginEnd="@dimen/brand_side_margin"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg" />

    <!-- Removed brandBarBottomLine for cleaner glassy look -->

    <!-- Settings button (shared screen; below brand bar, right corner) -->
    <ImageView
        android:id="@+id/btnAccount"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_settings"
        android:scaleType="centerInside"
        android:background="@drawable/bg_icon_button_soft"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:padding="9dp"
        android:tint="@color/icon_main_settings"
        android:contentDescription="@string/cd_settings"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="12dp"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Quay lại màn chọn chế độ (hiện ở cả Kid & Elder) — góc trái dưới brand bar -->
    <ImageView
        android:id="@+id/btnBackHome"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_arrow_back"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="9dp"
        android:tint="@color/icon_neutral"
        android:contentDescription="@string/back_to_mode_select"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Gọi khẩn cấp (chỉ hiện ở ELDER_CARE) — hàng dưới, cạnh phải mic, cùng cỡ mic/camera -->
    <ImageView
        android:id="@+id/btnEmergency"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_emergency"
        android:scaleType="centerInside"
        android:background="@drawable/bg_icon_button_soft"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:padding="@dimen/btn_mic_padding"
        android:tint="@color/icon_main_emergency"
        android:visibility="gone"
        android:contentDescription="@string/emergency_call"
        android:layout_marginStart="@dimen/space_hero_top"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintBottom_toBottomOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toEndOf="@id/btnHoldToTalk" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  GREETING TEXTS                                                    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Greeting frame: frosted glass card (ready to host live text later) -->
    <LinearLayout
        android:id="@+id/greetingCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_greeting_card"
        android:clipToOutline="true"
        android:elevation="6dp"
        android:minHeight="84dp"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        android:paddingTop="@dimen/space_l"
        android:paddingBottom="@dimen/space_l"
        android:layout_marginStart="@dimen/form_margin_h"
        android:layout_marginEnd="@dimen/form_margin_h"
        android:layout_marginTop="@dimen/space_l"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/greeting_hello"
            android:textSize="@dimen/text_greeting"
            android:textColor="@color/greeting_kid"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvSubGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/kid_sub_greeting"
            android:textSize="@dimen/text_sub_greeting"
            android:textStyle="bold"
            android:textColor="@color/accent_kid_dark"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_xs" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  WAVEFORM + CHARACTER (giữ nguyên thứ tự z-order gốc)            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- ① SÓNG ÂM — khai báo TRƯỚC ảnh để nằm phía sau -->
    <com.ctslab.ptalk_signature.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="@dimen/waveform_height"
        app:layout_constraintTop_toBottomOf="@id/greetingCard"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ② ẢNH NHÂN VẬT — khai báo SAU, nổi lên trên sóng -->
    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="@dimen/character_size"
        android:layout_height="@dimen/character_size"
        android:src="@drawable/char_idle1"
        android:scaleType="centerCrop"
        android:contentDescription="@string/cd_character"
        app:layout_constraintTop_toBottomOf="@id/greetingCard"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM CONTROLS                                                   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Text trạng thái -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textSize="@dimen/text_status"
        android:textColor="@color/status_kid"
        android:layout_marginBottom="@dimen/space_s"
        app:layout_constraintBottom_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vùng tròn bóng mờ báo hiệu huỷ ghi âm (kéo mic ra ngoài; mặc định ẩn) -->
    <View
        android:id="@+id/cancelZoneShadow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_circle_orange_pastel"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintBottom_toBottomOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="@id/btnHoldToTalk"
        app:layout_constraintEnd_toEndOf="@id/btnHoldToTalk" />

    <!-- Nút mic hold to talk (luôn ở giữa) -->
    <ImageButton
        android:id="@+id/btnHoldToTalk"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_mic_custom"
        android:background="@drawable/bg_hold_button"
        android:scaleType="centerInside"
        android:padding="@dimen/btn_mic_padding"
        android:layout_marginBottom="@dimen/space_xxl"
        android:elevation="6dp"
        android:contentDescription="@string/cd_record"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Quét thuốc (chỉ hiện ở ELDER_CARE) — ngang hàng mic, cùng kích thước -->
    <ImageButton
        android:id="@+id/btnScanMedicine"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_scan_medicine"
        android:background="@drawable/bg_camera_button"
        android:scaleType="centerInside"
        android:padding="@dimen/btn_mic_padding"
        android:tint="@color/accent_elder_dark"
        android:elevation="6dp"
        android:visibility="gone"
        android:contentDescription="@string/scan_medicine"
        android:layout_marginEnd="@dimen/space_hero_top"
        app:layout_constraintTop_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintBottom_toBottomOf="@id/btnHoldToTalk"
        app:layout_constraintEnd_toStartOf="@id/btnHoldToTalk" />

</androidx.constraintlayout.widget.ConstraintLayout>
