<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- Subtle animated star background -->
    <com.buivan.ptalk_child.StarFieldView
        android:id="@+id/starFieldView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BRAND BAR — PTIT + CTS logos (copyright / attribution strip)    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Removed brandAccentLine to use glassy header with margins -->

    <!-- Brand bar background (Glassy) -->
    <View
        android:id="@+id/brandBarBg"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PTIT Logo — left side (Circular crop để ẩn nền trắng) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivBrandPtitLeft"
        android:layout_width="@dimen/brand_ptit_size"
        android:layout_height="@dimen/brand_ptit_size"
        android:src="@drawable/logo_ptit"
        android:scaleType="centerCrop"
        android:layout_marginStart="@dimen/brand_side_margin"
        android:elevation="5dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Circle"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg" />

    <!-- Vertical separator removed -->
    <!-- App name & institution -->
    <LinearLayout
        android:id="@+id/brandTextBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KID MENTOR"
            android:textSize="@dimen/text_brand_title"
            android:textColor="@color/color_text_brand"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06" />
    </LinearLayout>

    <!-- CTS Logo — right side -->
    <ImageView
        android:id="@+id/ivBrandCtsRight"
        android:layout_width="@dimen/brand_cts_width"
        android:layout_height="@dimen/brand_cts_height"
        android:src="@drawable/logo_cts_main"
        android:scaleType="fitCenter"
        android:layout_marginEnd="@dimen/brand_side_margin"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg" />

    <!-- Removed brandBarBottomLine for cleaner glassy look -->

    <!-- ══ NAVIGATION BUTTON (below brand bar) ══════════════════════ -->

    <!-- Hamburger menu - right side -->
    <ImageView
        android:id="@+id/btnHamburger"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_menu_hamburger"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:tint="@color/color_hamburger_tint"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  GREETING TEXTS                                                    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_greeting"
        android:textSize="@dimen/text_greeting"
        android:textColor="@color/color_text_greeting"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnHamburger"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_sub_greeting"
        android:textSize="@dimen/text_sub_greeting"
        android:textStyle="bold"
        android:textColor="@color/color_text_sub_greeting"
        android:gravity="center"
        android:layout_marginTop="@dimen/space_xs"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  WAVEFORM + CHARACTER (giữ nguyên thứ tự z-order gốc)            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- ① SÓNG ÂM — khai báo TRƯỚC ảnh để nằm phía sau -->
    <com.buivan.ptalk_child.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="@dimen/waveform_height"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ② ẢNH NHÂN VẬT — khai báo SAU, nổi lên trên sóng -->
    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="@dimen/character_size"
        android:layout_height="@dimen/character_size"
        android:src="@drawable/char_idle1"
        android:scaleType="centerCrop"
        android:contentDescription="AI character"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM CONTROLS                                                   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Text trạng thái -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textSize="@dimen/text_status"
        android:textColor="@color/color_text_status"
        android:layout_marginBottom="@dimen/space_s"
        app:layout_constraintBottom_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vùng tròn bóng mờ báo hiệu huỷ (mặc định ẩn) -->
    <View
        android:id="@+id/cancelZoneShadow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_circle_orange_pastel"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintBottom_toBottomOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="@id/btnHoldToTalk"
        app:layout_constraintEnd_toEndOf="@id/btnHoldToTalk" />

    <!-- Nút mic hold to talk -->
    <ImageButton
        android:id="@+id/btnHoldToTalk"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_mic_custom"
        android:background="@drawable/bg_hold_button"
        android:scaleType="centerInside"
        android:padding="@dimen/btn_mic_padding"
        android:layout_marginBottom="@dimen/space_xxl"
        android:elevation="6dp"
        android:contentDescription="Ghi âm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
