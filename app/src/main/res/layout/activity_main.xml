<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <!-- Subtle animated star background (denser/brighter on the night screen) -->
    <com.ctslab.kidmentor.StarFieldView
        android:id="@+id/starFieldView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  GLASS HEADER — PTIT (left) · KID MENTOR · CTS (right)             -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/brandBarBg"
        android:layout_width="0dp"
        android:layout_height="@dimen/brand_bar_height"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_glass_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/ivBrandPtitLeft"
        android:layout_width="@dimen/brand_ptit_size"
        android:layout_height="@dimen/brand_ptit_size"
        android:src="@drawable/logo_ptit"
        android:scaleType="fitCenter"
        android:layout_marginStart="@dimen/brand_side_margin"
        android:elevation="5dp"
        android:contentDescription="PTIT"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg" />

    <LinearLayout
        android:id="@+id/brandTextBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintStart_toStartOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KID MENTOR"
            android:textSize="@dimen/text_brand_title"
            android:textColor="@color/color_text_brand"
            android:fontFamily="@font/baloo2"
            android:textFontWeight="700"
            android:letterSpacing="0.12" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivBrandCtsRight"
        android:layout_width="@dimen/brand_cts_width"
        android:layout_height="@dimen/brand_cts_height"
        android:src="@drawable/logo_cts_main"
        android:scaleType="fitCenter"
        android:layout_marginEnd="@dimen/brand_side_margin"
        android:elevation="5dp"
        android:contentDescription="CTS"
        app:layout_constraintTop_toTopOf="@id/brandBarBg"
        app:layout_constraintBottom_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="@id/brandBarBg" />

    <!-- Hamburger menu (opens the Sáng/Tối/Theo hệ thống + account menu) -->
    <ImageView
        android:id="@+id/btnHamburger"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_menu_hamburger"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:tint="@color/color_hamburger_tint"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="12dp"
        android:contentDescription="Menu"
        app:layout_constraintTop_toBottomOf="@id/brandBarBg"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  WELCOME CARD — frosted glass panel showing only the greeting.      -->
    <!--  (Demo-safe: the live transcript/learning blocks come later, once   -->
    <!--   the server sends conversation text — see Phase 1 design.)         -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatPanelScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:layout_marginTop="@dimen/space_m"
        android:background="@drawable/bg_chat_panel"
        android:elevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnHamburger"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/km_chat_panel_padding"
            android:paddingVertical="20dp">

            <!-- In-panel greeting (mascot speaks as a friend: tớ/cậu) -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_greeting"
                android:gravity="center"
                android:fontFamily="@font/baloo2"
                android:textFontWeight="600"
                android:textSize="@dimen/km_text_panel_hello"
                android:textColor="@color/km_panel_hello" />

            <TextView
                android:id="@+id/tvSubGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_sub_greeting"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_xs"
                android:fontFamily="@font/baloo2"
                android:textFontWeight="700"
                android:textSize="@dimen/km_text_panel_hello_sub"
                android:textColor="@color/km_panel_hello_sub" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  MASCOT + WAVEFORM — large, centered below the welcome card         -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <com.ctslab.kidmentor.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="@dimen/waveform_height"
        app:layout_constraintTop_toBottomOf="@id/chatPanelScroll"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/ivCharacter"
        android:layout_width="@dimen/character_size"
        android:layout_height="@dimen/character_size"
        android:src="@drawable/char_idle1"
        android:scaleType="centerCrop"
        android:contentDescription="AI character"
        app:layout_constraintTop_toBottomOf="@id/chatPanelScroll"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM CONTROLS                                                    -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:fontFamily="@font/nunito"
        android:textSize="@dimen/text_status"
        android:textColor="@color/color_text_status"
        android:layout_marginBottom="@dimen/space_s"
        app:layout_constraintBottom_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/cancelZoneShadow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_circle_orange_pastel"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/btnHoldToTalk"
        app:layout_constraintBottom_toBottomOf="@id/btnHoldToTalk"
        app:layout_constraintStart_toStartOf="@id/btnHoldToTalk"
        app:layout_constraintEnd_toEndOf="@id/btnHoldToTalk" />

    <ImageButton
        android:id="@+id/btnHoldToTalk"
        android:layout_width="@dimen/btn_mic_size"
        android:layout_height="@dimen/btn_mic_size"
        android:src="@drawable/ic_mic_custom"
        android:background="@drawable/bg_hold_button"
        android:scaleType="centerInside"
        android:padding="@dimen/btn_mic_padding"
        android:layout_marginBottom="@dimen/space_xxl"
        android:elevation="6dp"
        android:contentDescription="Ghi âm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
