<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#222222"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/profile_header"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111111"/>

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerProfile"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <!-- User Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardUserInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:orientation="vertical"
                     android:padding="24dp"
                     android:gravity="center">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/char_idle1"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/tvProfileUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/tvProfileTier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_free_member"
                        android:textSize="16sp"
                        android:textColor="#707072"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quota Usage Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardQuota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/profile_quota_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:id="@+id/tvQuotaCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 20"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D52"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressQuota"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/bg_progress_quota" />

                    <TextView
                        android:id="@+id/tvQuotaHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_quota_hint_basic"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Gói dịch vụ Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_subscription_title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.05"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="8dp"/>

            <!-- Segmented plan selector (reuses the language-toggle pill style) -->
            <LinearLayout
                android:id="@+id/planTabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_lang_toggle"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tabPlanBasic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="@string/profile_plan_basic"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#707072" />

                <TextView
                    android:id="@+id/tabPlanPro"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="@string/profile_plan_pro"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#707072" />

                <TextView
                    android:id="@+id/tabPlanUltra"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="@string/profile_plan_ultra"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#707072" />
            </LinearLayout>

            <!-- Selected-plan detail card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvPlanName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textColor="#1A1A2E" />
                        <TextView
                            android:id="@+id/tvPlanBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#E07B20"
                            android:background="#FFF3E0"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPlanQuota"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="#666666"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/tvPlanPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginTop="6dp" />

                    <Button
                        android:id="@+id/btnPlanAction"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/profile_btn_upgrade"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#2196F3"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Gói sản phẩm vật lý Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_physical_title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.05"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="8dp"/>

            <!-- PHYSICAL DEVICE CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_physical_name"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#E07B20"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_physical_desc"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_physical_price"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#D30005"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyDevice"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/profile_physical_btn_buy"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#D30005"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Đăng xuất -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/profile_btn_logout"
                android:backgroundTint="#FFF0F0"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="0dp"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
