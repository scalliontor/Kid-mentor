<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:id="@+id/headerChildren"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#222222"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/children_header"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111111" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerChildren"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/form_margin_h"
            android:paddingEnd="@dimen/form_margin_h"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/children_subtitle"
                android:textSize="@dimen/text_login_subheadline"
                android:textColor="#707072"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <!-- Children rows injected here -->
            <LinearLayout
                android:id="@+id/childrenContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvChildrenEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/children_empty"
                android:textSize="14sp"
                android:textColor="#999999"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/children_edit_on_dashboard"
                android:textSize="@dimen/text_login_label"
                android:textColor="#9E9EA0"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <ProgressBar
                android:id="@+id/progressChildren"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_l"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
